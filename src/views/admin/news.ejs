<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="container page">
  <section class="panel">
    <div class="actions-row">
      <h1>Управление новостями</h1>
      <a class="btn" href="/admin/news/new">+ Новость</a>
    </div>

    <table>
      <thead>
      <tr>
        <th>ID</th>
        <th>Заголовок</th>
        <th>Статус</th>
        <th>Дата</th>
        <th>Действия</th>
      </tr>
      </thead>
      <tbody>
      <% news.forEach(item => { %>
        <tr>
          <td><%= item.id %></td>
          <td><%= item.title %></td>
          <td><%= item.is_published ? 'Опубликовано' : 'Черновик' %></td>
          <td><%= new Date(item.published_at).toLocaleDateString('ru-RU') %></td>
          <td class="row-actions">
            <a class="btn btn-outline" href="/admin/news/<%= item.id %>/edit">Изменить</a>
            <form method="post" action="/admin/news/<%= item.id %>/delete" onsubmit="return confirm('Удалить новость?');">
              <button class="btn danger" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </section>
</main>

<%- include('../partials/footer') %>
