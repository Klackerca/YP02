<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="container page">
  <article class="panel news-detail">
    <h1><%= item.title %></h1>
    <p class="muted"><%= new Date(item.published_at).toLocaleDateString('ru-RU') %></p>
    <img src="<%= item.image_url || 'https://images.unsplash.com/photo-1521337581100-8ca9a73a5f79?auto=format&fit=crop&w=1200&q=80' %>" alt="<%= item.title %>" />
    <div class="news-content"><%- item.body %></div>
    <a class="btn btn-outline" href="/news">← К списку новостей</a>
  </article>
</main>

<%- include('../partials/footer') %>
